@model IEnumerable<Item>
@{
    ViewData["Title"] = "Items Dashboard";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Items Dashboard</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Item</a>
</div>

<div class="glass-card" style="margin-bottom: 2rem;">
    <form asp-action="Index" method="get" style="display: flex; gap: 1rem;">
        <input type="text" name="searchString" class="form-control" placeholder="Search items by name..." style="flex: 1;" />
        <button type="submit" class="btn btn-secondary">Search</button>
    </form>
</div>

<div class="glass-card">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Weight</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Weight</td>
                    <td>
                        <span class="badge @(item.Status == "Processed" ? "badge-processed" : "badge-unprocessed")">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary" style="padding: 0.25rem 0.75rem; font-size: 0.875rem;">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this item? Children will also be deleted.');">
                            <button type="submit" class="btn btn-danger" style="padding: 0.25rem 0.75rem; font-size: 0.875rem;">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align: center; padding: 2rem 0; color: var(--text-muted);">No items found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
